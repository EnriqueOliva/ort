# Submission bundles (redundant with tracked source files)
# ==============================================================================
*.zip

# ==============================================================================
# Cloned reference repositories (third-party code used for research)
# ==============================================================================
**/myResearch/workingImplementations/

# ==============================================================================
# Large media (raw class recordings — too large for git)
# ==============================================================================
*.mp4
*.avi
*.mkv
*.mov
*.webm

# Allow compressed class videos (<95MB parts) in project
!**/classesVideos/**/*.mp4

# ==============================================================================
# Log files
